void TIM1_init(){

	RCC -> APB2ENR |= 1;

	TIM1 -> PSC = 15; // PSC + 1 = 16. Divide the 16MHz clock by 16 means the register will update every 1us.

	TIM1 -> EGR |= (1 << 0); //Trigger an event so the prescalar is loaded

	TIM1 -> SR = 0; // Clear Status register

	TIM1 -> CR1 |= (1 << 3); // Set one pulse mode so clock disables itself.

}

void TIM2_init(){

	RCC -> APB1ENR |= 1;

	TIM2 -> PSC = 15999; // PSC + 1 = 16000. Divide the 16MHz clock by 16k means the register will update every 1ms.

	TIM2 -> CNT = 0;

	TIM2 -> ARR = 60000;

	TIM2 -> EGR |= (1 << 0); //Trigger an event so the prescalar is loaded

	TIM2 -> SR &= ~(1 << 0);

	TIM2 -> CR1 |= (1 << 0); //Start time 2

}

void countMinAndSec(void){
	TIM2_init(); // Init Timmer 2

	initPC13();  // Init PC 13

	char buffer[50];
	int minutes = 0;
	int seconds = 0;

	int prevSeconds = -1;
	int prevMinutes = -1;



	//While button is not pressed
	while((GPIOC -> IDR & (1 << 13))){
		seconds = TIM2 -> CNT / 1000;

		if(TIM2 -> SR & (1 << 0)){
			minutes++;
			TIM2 -> SR &= ~(1 << 0); //Reset SR after a value is read
		}

		if(minutes != prevMinutes){
			prevMinutes = minutes;
			//print minutes to specific lcd location
			sprintf(buffer, "%02d", minutes);
			LCD_Command(0x80 | 0x0);
			_sysTick_delay_ms(10);
			LCD_String(buffer);
		}

		if(seconds != prevSeconds){
			prevSeconds = seconds;
			//Print seconds to specific LCD location
			sprintf(buffer, "%02d", seconds);
			LCD_Command(0x80 | 0x40);
			_sysTick_delay_ms(10);
			LCD_String(buffer);
			_sysTick_delay_ms(10);
		}
	}

}

void WriteMinutesAndSeconds(){
	LCD_Command(0x80 | 0x2); //Move cursor to 0x02
	_sysTick_delay_ms(10);
	LCD_String(" minute(s)");

	LCD_Command(0x80 | 0x42); //Move cursor to 0x42
	_sysTick_delay_ms(10);
	LCD_String(" second(s)");
}

void _sysTick_delay_ms(int n){
		int i;
		for (i= 0; i < n; i ++)
		{
			while ((SysTick->CTRL & 0x10000) == 0){}
		}
	return;
}

void _delay_us(int n){

	TIM1 -> CNT = 0; //Clear current count

	TIM1 -> ARR = n - 1; //Set the ARR so an event is triggered on the specified time interval.

	TIM1 -> SR = 0;//Clear the status register

	TIM1 -> CR1 |= (1 << 0); //Enable counter in control register


}


void SysTick_Init(void){
	SysTick -> LOAD = (SystemCoreClock / 1000) - 1;
	SysTick->VAL = 0;
	SysTick->CTRL &= ~(0x07);
	SysTick->CTRL |= 0x05;
}


void initPC13(void){
	RCC -> AHB1ENR |= 1 << 2;
	GPIOC -> MODER &= ~(3 << 30);

}

void LCD_Pulse_EN(void) {

GPIOB->BSRR = (1 << 7); // Set PB7 (EN) HIGH


_sysTick_delay_ms(10); // Wait a tiny bit for LCD to read

GPIOB->BSRR = (1 << (7 + 16));// Set PB7 (EN) LOW

_sysTick_delay_ms(2); // Wait for command to execute

}

void LCD_Command(unsigned char cmd) {

GPIOB->BSRR = (1 << (5 + 16)); // RS = 0 for command (PB5 LOW)

GPIOB->BSRR = (1 << (6 + 16)); // RW = 0 for write (PB6 LOW)

// Put the 8-bit command onto Port C (PC0-PC7)

// We mask the lower 8 bits so we don't disturb PC8-PC15

GPIOC->ODR = (GPIOC->ODR & 0xFF00) | cmd;



LCD_Pulse_EN(); // Latch the command

}

void LCD_Init_8Bit(void) {

// 1. Enable clocks for Port B (Control) and Port C (Data)

RCC->AHB1ENR |= RCC_AHB1ENR_GPIOBEN | RCC_AHB1ENR_GPIOCEN;



// 2. Configure PB5, PB6, PB7 as General Purpose Outputs

// Clear the mode bits first, then set to 01 (Output)

GPIOB->MODER &= ~((3 << 10) | (3 << 12) | (3 << 14));

GPIOB->MODER |= ((1 << 10) | (1 << 12) | (1 << 14));



// 3. Configure PC0 to PC7 as General Purpose Outputs

GPIOC->MODER &= 0xFFFF0000; // Clear mode bits for PC0-PC7

GPIOC->MODER |= 0x00005555; // Set PC0-PC7 to 01 (Output mode)



// 4. LCD Boot-up Sequence

_sysTick_delay_ms(20); // Wait >15ms after power on



LCD_Command(0x30); // Wake up / Function set

_sysTick_delay_ms(5); // Wait >4.1ms



LCD_Command(0x30); // Wake up 2

_delay_us(150); // Wait >100us



LCD_Command(0x30); // Wake up 3



// 5. Initial Display Configuration

LCD_Command(0x38); // Function Set: 8-bit interface, 2 lines, 5x8 font

LCD_Command(0x0C); // Display control: Display ON, Cursor OFF, Blink OFF

LCD_Command(0x01); // Clear Display

_sysTick_delay_ms(2); // Clear display requires extra time

LCD_Command(0x06); // Entry Mode: Auto-increment cursor, no display shift

}

void LCD_Data(unsigned char data) {

GPIOB->BSRR = (1 << 5); // RS = 1 for data (PB5 HIGH)

GPIOB->BSRR = (1 << (6 + 16)); // RW = 0 for write (PB6 LOW)



// Put the 8-bit character data onto Port C (PC0-PC7)

// We mask the lower 8 bits so we don't disturb PC8-PC15

GPIOC->ODR = (GPIOC->ODR & 0xFF00) | data;



LCD_Pulse_EN(); // Latch the data

}



void LCD_String(char* str) {

while (*str) { // Loop until we hit the null terminator '\0'

LCD_Data(*str); // Send the current character

str++; // Move to the next character

}

}


void togglePA5(bool state){
	RCC -> AHB1ENR |= 1 << 0; //Enable Advanced High Performance Bus

	GPIOA -> MODER |= 01 << 10; //

	if(state){
		GPIOA -> ODR |= 1 << 5;
	}

	if(~state){
		GPIOA -> ODR &= ~(0x00000020);
	}

}
