void TIM1_init(){
	RCC -> APB1ENR |= 0;
	RCC -> APB2ENR |= 1;

	RCC -> TIM1_PSC &= 0;
	RCC -> TIM1_PSC |= 15999; // PSC + 1 = 16000. Divide the 16MHz clock by 16k means the register will update every 1ms.


	RCC -> TIM1_EGR |= 1;

	RCC -> TIMX_CR1 &= 0;
	RCC -> TIMX_CR1 |= (1 << 4);

}

